# One App Backend - Environment Variables
# Copy this file to .env and fill in your values

# ============================================================
# Server Configuration
# ============================================================
NODE_ENV=development
PORT=3000
API_URL=http://localhost:3000
API_PREFIX=/api/v1

# ============================================================
# Database Configuration
# ============================================================
DATABASE_URL=postgresql://oneapp_user:your_password@localhost:5432/oneapp
DB_HOST=localhost
DB_PORT=5432
DB_USER=oneapp_user
DB_PASSWORD=your_password
DB_NAME=oneapp
DB_SSL=false
DB_POOL_MIN=2
DB_POOL_MAX=10

# ============================================================
# Redis Configuration
# ============================================================
REDIS_URL=redis://localhost:6379
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# ============================================================
# JWT Configuration
# ============================================================
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRY=1h
JWT_REFRESH_SECRET=your-super-secret-refresh-key-change-this-in-production
JWT_REFRESH_EXPIRY=7d

# ============================================================
# KYC Provider (Smile Identity)
# ============================================================
KYC_PROVIDER=smile_identity
KYC_API_KEY=your_kyc_api_key
KYC_PARTNER_ID=your_partner_id
KYC_API_URL=https://testapi.smileidentity.com/v1
KYC_CALLBACK_URL=http://localhost:3000/api/v1/webhooks/kyc

# ============================================================
# Card Provider (Budpay)
# ============================================================
CARD_PROVIDER=budpay
CARD_API_KEY=your_card_api_key
CARD_SECRET_KEY=your_card_secret_key
CARD_API_URL=https://api.budpay.com/api/v2
CARD_WEBHOOK_SECRET=your_webhook_secret

# ============================================================
# Payment Provider (Paystack)
# ============================================================
PAYMENT_PROVIDER=paystack
PAYMENT_PUBLIC_KEY=pk_test_xxxxx
PAYMENT_SECRET_KEY=sk_test_xxxxx
PAYMENT_API_URL=https://api.paystack.co
PAYMENT_WEBHOOK_SECRET=your_webhook_secret

# ============================================================
# Meta WhatsApp Business (One Bot)
# ============================================================
META_APP_ID=your_meta_app_id
META_APP_SECRET=your_meta_app_secret
META_WHATSAPP_PHONE_ID=your_whatsapp_phone_id
META_WHATSAPP_BUSINESS_ACCOUNT_ID=your_business_account_id
META_WEBHOOK_VERIFY_TOKEN=your_webhook_verify_token
META_ACCESS_TOKEN=your_permanent_access_token

# ============================================================
# AWS S3 (Document Storage)
# ============================================================
AWS_ACCESS_KEY_ID=your_access_key
AWS_SECRET_ACCESS_KEY=your_secret_key
AWS_REGION=us-east-1
AWS_S3_BUCKET=oneapp-documents
AWS_S3_KYC_BUCKET=oneapp-kyc-docs

# ============================================================
# Encryption
# ============================================================
ENCRYPTION_KEY=your-32-character-encryption-key
ENCRYPTION_ALGORITHM=aes-256-gcm

# ============================================================
# Rate Limiting
# ============================================================
RATE_LIMIT_TTL=60
RATE_LIMIT_MAX=100

# ============================================================
# CORS
# ============================================================
CORS_ORIGIN=http://localhost:3000,http://localhost:3001
CORS_CREDENTIALS=true

# ============================================================
# Logging
# ============================================================
LOG_LEVEL=debug
LOG_FILE_PATH=./logs

# ============================================================
# Monitoring (Sentry)
# ============================================================
SENTRY_DSN=
SENTRY_ENVIRONMENT=development

# ============================================================
# Campaign Configuration
# ============================================================
FIRST_5K_PROMO_AMOUNT=5000
FIRST_5K_PROMO_CURRENCY=NGN
FIRST_5K_PROMO_MAX_USERS=5000

# ============================================================
# Fees Configuration
# ============================================================
ONE_SHARE_ISSUANCE_FEE=100
ONE_SHARE_ISSUANCE_FEE_PERCENT=2
WITHDRAWAL_FEE_FIXED=50
WITHDRAWAL_FEE_PERCENT=1
CARD_CREATION_FEE=200

# ============================================================
# Business Rules
# ============================================================
MIN_WITHDRAWAL_AMOUNT=1000
MAX_ONE_SHARE_AMOUNT=1000000
ONE_SHARE_EXPIRY_DAYS=30
PIN_MAX_ATTEMPTS=3
OTP_EXPIRY_MINUTES=10
